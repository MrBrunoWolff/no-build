{
  "name": "no-build",
  "version": "1.0.0",
  "description": "Example of a no-build web project using JS/TS",
  "type": "module",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "nodemon --watch src --ext ts --exec tsx src/server.ts",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.30",
    "nodemon": "^2.0.22",
    "ts-node": "^10.9.1",
    "tsx": "^4.19.4",
    "typescript": "^5.0.0"
  }
}
