{
  "name": "no-build",
  "version": "0.1.0",
  "description": "A modern Rails template with no build steps using Import Maps and Propshaft",
  "author": "Bruno Wolff <bruno@example.com>",
  "license": "MIT",
  "type": "module",
  "main": "bin/no-build.js",
  "bin": {
    "no-build": "bin/no-build.js"
  },
  "files": [
    "bin",
    "app",
    "config",
    "Gemfile",
    "Gemfile.lock",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "rails",
    "importmap",
    "propshaft",
    "no-build",
    "hotwire",
    "stimulus",
    "turbo"
