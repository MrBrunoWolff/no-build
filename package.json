  },
  "scripts": {
    "start": "bin/rails server",
    "create": "node bin/no-build.js"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "fs-extra": "^11.3.0",
    "inquirer": "^12.6.1"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}