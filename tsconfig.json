{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "ts-node": {
    "experimentalSpecifierResolution": "node",
    "compilerOptions": {
      "module": "NodeNext"
    }
  }
}
