<div class="welcome">
  <h2>Welcome to No-Build Rails!</h2>
  
  <p>
    This is a Rails application using modern techniques without build steps:
  </p>
  
  <ul>
    <li>Vanilla ES6 JavaScript with Import Maps</li>
    <li>Modern CSS with nesting and variables</li>
    <li>Propshaft asset pipeline</li>
    <li>Hotwire for SPA-like experiences</li>
  </ul>
  
  <div class="demo">
    <button>Click me!</button>
    <p class="output"></p>
  </div>
</div>

<div class="card mt-md">
  <h2 class="card-title">Getting Started</h2>
  <div class="card-body">
    <p>Start modifying this template to build your application:</p>
    
    <ol>
      <li>Edit views in <code>app/views/</code></li>
      <li>Add your own styles to <code>app/assets/stylesheets/application.css</code></li>
      <li>Add JavaScript functionality in <code>app/javascript/</code></li>
      <li>Create Stimulus controllers in <code>app/javascript/controllers/</code></li>
    </ol>
    
    <p class="mt-md">For more information, check out the <a href="https://github.com/MrBrunoWolff/no-build">documentation</a>.</p>
  </div>
</div>

<% # This demonstrates using Turbo Frames %>
<turbo-frame id="demo-frame">
  <div class="card mt-md">
    <h2 class="card-title">Turbo Frame Example</h2>
    <div class="card-body">
      <p>This is a Turbo Frame that can be dynamically updated without full page reloads.</p>
      <p>Click the button below to see it in action:</p>
      
      <%= link_to "Load Content", turbo_demo_path, class: "button button-secondary", data: { turbo_frame: "demo-frame" } %>
    </div>
  </div>
</turbo-frame> 